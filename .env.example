DATABASE_URL="file:./dev.db"
POLYMARKET_API_BASE="https://gamma-api.polymarket.com"
# 可选：手工固定事件 slug；留空则自动抓“上海次日最高温”盘口
# POLYMARKET_EVENT_SLUG=""
TOTAL_CAPITAL="10000"
MAX_SINGLE_TRADE_PERCENT="0.1"
POLYMARKET_TIMEOUT_MS="12000"
# 当天盘口进入结算窗口后（默认提前240分钟）自动切换到次日盘口
MARKET_ROLLOVER_WINDOW_MINUTES="240"
MIN_EDGE_TO_TRADE="0.03"
MIN_UPSIDE_TO_TRADE="0.05"
MIN_SIDE_PROB_TO_TRADE="0.55"
TRADING_COST_PER_TRADE="0.01"
SKIP_NEAR_CERTAIN_PRICE="0.97"
# 对“日最高温”连续融合值转整数锚点时的上偏阈值（14.35+ -> 15）
MAX_TEMP_UPSHIFT_THRESHOLD="0.35"
KELLY_FRACTION="0.25"
MAX_SINGLE_RISK_PERCENT="0.02"
DAILY_RISK_PERCENT="0.05"
BIAS_LOOKBACK_DAYS="30"
BIAS_MIN_TOTAL_SAMPLES="10"
BIAS_MIN_SOURCE_SAMPLES="3"
# 决策模式: realtime（每次刷新都重新计算）
DECISION_POLICY="realtime"
# 严格模式必需天气源（逗号分隔）
# 默认建议: open_meteo,wttr,met_no
# 如需把付费源也设为硬门槛: open_meteo,wttr,met_no,weatherapi,qweather
WEATHER_STRICT_SOURCES="open_meteo,wttr,met_no"
# WeatherAPI: 可选增强源；仅当 WEATHER_STRICT_SOURCES 包含 weatherapi 时才作为硬门槛
WEATHERAPI_KEY=""
# 可选：默认 api.weatherapi.com/v1
WEATHERAPI_API_BASE="https://api.weatherapi.com/v1"
# QWeather: 可选增强源；仅当 WEATHER_STRICT_SOURCES 包含 qweather 时才作为硬门槛
QWEATHER_API_KEY=""
# 可选：默认 devapi.qweather.com
QWEATHER_API_BASE="https://devapi.qweather.com"
# 可选：若 Wunderground/Weather.com key 变更，可手动设置
# WUNDERGROUND_API_KEY=""
